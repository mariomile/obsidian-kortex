{
  "name": "obsidian-exo",
  "version": "0.8.1",
  "description": "Exo — an agentic AI assistant in your Obsidian sidebar, powered by the Claude or Codex CLI, with a custom theme-aware chat UI.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "claude",
    "codex",
    "ai",
    "agent"
  ],
  "author": "Mario Miletta",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.195",
    "zod": "^4.4.3"
  }
}
